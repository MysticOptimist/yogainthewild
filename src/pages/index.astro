---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

// Placeholders — update before launch
const e8YogaLink = '#';
const yogaPodLink = '#';
const contactEmail = '';
const eventDate = 'Coming Fall 2026';
---

<Layout title="Yoga in the Wild — A Practice with Purpose">
<div style="background:#F4EEE2; overflow-x:hidden;">

  <!-- ============ HEADER ============ -->
  <header style="position:sticky; top:0; z-index:50; background:rgba(244,238,226,0.88); backdrop-filter:blur(10px); border-bottom:1px solid rgba(43,58,45,0.10);">
    <div style="max-width:1180px; margin:0 auto; padding:16px 24px; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap;">
      <a href="#top" style="display:flex; align-items:center; gap:11px;">
        <span style="width:30px; height:30px; border-radius:50%; border:1.5px solid #2B3A2D; display:inline-flex; align-items:center; justify-content:center;">
          <span style="width:8px; height:8px; border-radius:50%; background:#B58A47;"></span>
        </span>
        <span style="font-family:'Lora',serif; font-size:20px; font-weight:600; letter-spacing:0.01em; color:#2B3A2D;">Yoga in the Wild</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav-links" style="display:flex; align-items:center; gap:30px; flex-wrap:wrap;">
        <a href="#about" style="font-size:14.5px; color:#4A4A42; font-weight:500;">About</a>
        <a href="#schedule" style="font-size:14.5px; color:#4A4A42; font-weight:500;">Schedule</a>
        <a href="#included" style="font-size:14.5px; color:#4A4A42; font-weight:500;">What's Included</a>
        <a href="#sanctuary" style="font-size:14.5px; color:#4A4A42; font-weight:500;">Sanctuary</a>
        <a href="#register" style="font-size:14.5px; color:#4A4A42; font-weight:500;">Studios</a>
        <a href="#faq" style="font-size:14.5px; color:#4A4A42; font-weight:500;">FAQ</a>
        <a href="#register" class="btn-pill" style="font-size:14px; font-weight:600; color:#FBF8F1; background:#2B3A2D; padding:10px 20px;">Register</a>
      </nav>
    </div>
  </header>

  <!-- ============ HERO ============ -->
  <section id="top" style="position:relative; min-height:92vh; display:flex; align-items:flex-end; padding:0;">
    <img src="/assets/bear-walkway.jpg" alt="A rescued bear grazing beneath the elevated walkway at The Wild Animal Sanctuary" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 38%;" loading="eager" />
    <div style="position:absolute; inset:0; background:linear-gradient(100deg, rgba(28,38,29,0.86) 0%, rgba(28,38,29,0.55) 38%, rgba(28,38,29,0.12) 66%, rgba(28,38,29,0.05) 100%);"></div>
    <div style="position:relative; max-width:1180px; margin:0 auto; width:100%; padding:clamp(40px,7vw,96px) 24px clamp(48px,6vw,80px);">
      <div style="max-width:720px;">
        <p style="margin:0 0 22px; font-size:13px; letter-spacing:0.22em; text-transform:uppercase; font-weight:600; color:#D8C28C;">A one-day yoga fundraiser</p>
        <h1 style="margin:0; font-family:'Lora',serif; font-weight:500; color:#FBF8F1; font-size:clamp(44px,7.5vw,86px); line-height:0.98; letter-spacing:-0.01em; white-space:nowrap;">Yoga in the Wild</h1>
        <p style="margin:18px 0 0; font-family:'Lora',serif; font-style:italic; font-size:clamp(22px,3vw,30px); color:#E7D9B6; font-weight:400;">A Practice with Purpose</p>
        <p style="margin:26px 0 0; font-size:clamp(16px,1.4vw,18px); line-height:1.65; color:rgba(251,248,241,0.92); max-width:540px;">A day of movement, compassion, and conservation at The Wild Animal Sanctuary in Keenesburg, Colorado. Your registration includes one yoga class and a full-day sanctuary pass.</p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; margin:30px 0 0;">
          <span style="display:inline-flex; align-items:center; gap:7px; font-size:13.5px; font-weight:500; color:#FBF8F1; background:rgba(251,248,241,0.12); border:1px solid rgba(251,248,241,0.28); padding:8px 15px; border-radius:999px;">Fall 2026</span>
          <span style="display:inline-flex; align-items:center; gap:7px; font-size:13.5px; font-weight:500; color:#FBF8F1; background:rgba(251,248,241,0.12); border:1px solid rgba(251,248,241,0.28); padding:8px 15px; border-radius:999px;">Keenesburg, CO</span>
          <span style="display:inline-flex; align-items:center; gap:7px; font-size:13.5px; font-weight:500; color:#FBF8F1; background:rgba(251,248,241,0.12); border:1px solid rgba(251,248,241,0.28); padding:8px 15px; border-radius:999px;">$100 per person</span>
          <span style="display:inline-flex; align-items:center; gap:7px; font-size:13.5px; font-weight:500; color:#FBF8F1; background:rgba(251,248,241,0.12); border:1px solid rgba(251,248,241,0.28); padding:8px 15px; border-radius:999px;">Ages 14+</span>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:14px; margin:32px 0 0;">
          <a href="#register" class="btn-pill" style="font-size:15.5px; color:#2B3A2D; background:#E7D9B6; padding:15px 28px;">Register for a Class</a>
          <a href="#sanctuary" class="btn-pill" style="font-size:15.5px; font-weight:500; color:#FBF8F1; border:1.5px solid rgba(251,248,241,0.45); padding:15px 26px;">Learn About the Sanctuary</a>
        </div>
        <p style="margin:26px 0 0; font-size:14px; color:rgba(251,248,241,0.82); display:flex; align-items:center; gap:9px;">
          <span style="width:7px; height:7px; border-radius:50%; background:#B58A47;"></span>
          100% of event proceeds go to The Wild Animal Sanctuary.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ AT A GLANCE ============ -->
  <section id="details" style="padding:clamp(48px,6vw,72px) 24px;">
    <div style="max-width:1180px; margin:0 auto;">
      <div data-reveal class="gridline-container" style="grid-template-columns:repeat(auto-fit, minmax(min(100%, 320px), 1fr));">
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Date</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">{eventDate}</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">A Saturday or Sunday, mid-August to mid-October.</p>
        </div>
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Location</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">The Wild Animal Sanctuary</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">Keenesburg, Colorado.</p>
        </div>
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Cost</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">$100 per participant</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">Every dollar supports the Sanctuary.</p>
        </div>
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Includes</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">One class + full-day pass</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">A 60-minute yoga class and sanctuary admission.</p>
        </div>
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Who Can Attend</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">Adults & youth 14+</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">Youth ages 14+ with parental permission.</p>
        </div>
        <div class="gridline-cell">
          <p class="eyebrow eyebrow--sm" style="margin-bottom:10px;">Fundraising Goal</p>
          <p style="margin:0; font-family:'Lora',serif; font-size:21px; color:#2B3A2D; line-height:1.25;">$10,000 raised</p>
          <p style="margin:8px 0 0; font-size:14px; color:#6B6B5F; line-height:1.5;">For rescued wild animals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section id="about" style="padding:clamp(52px,5.5vw,76px) 24px; background:#E3E8D6;">
    <div data-reveal style="max-width:1080px; margin:0 auto;">
      <p class="eyebrow" style="margin-bottom:20px;">About the event</p>
      <h2 class="section-heading" style="font-size:clamp(30px,4.2vw,48px); line-height:1.06;">A day of yoga, compassion, and conservation</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:clamp(28px,4vw,56px); margin-top:clamp(36px,4vw,52px); padding-top:clamp(30px,3vw,40px); border-top:1px solid rgba(43,58,45,0.18);">
        <p style="margin:0; font-size:clamp(18px,1.5vw,20px); line-height:1.7; color:#2B3A2D;">Yoga in the Wild is a collaborative one-day fundraiser bringing together Longmont-area yoga studios and community members in support of The Wild Animal Sanctuary. Participants choose one 60-minute class and receive a full-day pass to explore the elevated walkway, Welcome Center, and Education Center.</p>
        <div>
          <p style="margin:0; font-size:17px; line-height:1.75; color:#5A5A50;">The day connects the values of yoga — especially <em style="font-style:italic; color:#2B3A2D;">ahimsa</em>, or non-harming — with practical action on behalf of rescued wild animals.</p>
          <p style="margin:26px 0 0; padding-left:22px; border-left:2px solid #B58A47; font-family:'Lora',serif; font-style:italic; font-size:clamp(20px,1.9vw,25px); line-height:1.35; color:#2B3A2D;">We move with purpose, and we practice in service.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MISSION / IMPACT (tiger) ============ -->
  <section style="padding:clamp(12px,2vw,28px) 24px clamp(56px,6vw,84px); background:#E3E8D6;">
    <div data-reveal style="max-width:1180px; margin:0 auto; border-radius:20px; overflow:hidden; position:relative; min-height:clamp(420px,52vw,560px); display:flex; align-items:flex-end;">
      <img src="/assets/tiger-mountains.jpg" alt="A rescued tiger walking through prairie grass with the snowcapped Rocky Mountains behind" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 85%;" loading="lazy" />
      <div style="position:absolute; inset:0; background:linear-gradient(0deg, rgba(28,38,29,0.88) 0%, rgba(28,38,29,0.35) 42%, rgba(28,38,29,0.05) 100%);"></div>
      <div style="position:relative; padding:clamp(32px,5vw,56px); max-width:680px;">
        <p class="eyebrow eyebrow--light">Why it matters</p>
        <h2 class="section-heading" style="color:#FBF8F1; font-size:clamp(28px,3.6vw,44px);">Every registration supports lifelong care</h2>
        <p style="margin:20px 0 0; font-size:17px; line-height:1.7; color:rgba(251,248,241,0.92);">The Wild Animal Sanctuary rescues and provides lifelong homes for large, exotic, and endangered captive wild animals — offering hundreds of rescued animals space, care, dignity, and safety.</p>
      </div>
    </div>
  </section>

  <!-- ============ SCHEDULE ============ -->
  <section id="schedule" style="padding:clamp(64px,8vw,104px) 24px;">
    <div style="max-width:1180px; margin:0 auto;">
      <div data-reveal style="max-width:640px; margin-bottom:48px;">
        <p class="eyebrow">Class schedule</p>
        <h2 class="section-heading" style="font-size:clamp(30px,4vw,46px);">Choose one 60-minute class</h2>
        <p style="margin:18px 0 0; font-size:17px; line-height:1.7; color:#4A4A42;">Arrive 30-60 minutes before your class — or earlier in the day to explore. The Sanctuary opens at 9:00 AM.</p>
      </div>
      <div data-reveal style="border-top:1px solid rgba(43,58,45,0.16);">
        <div style="display:flex; align-items:baseline; gap:clamp(16px,4vw,48px); padding:24px 4px; border-bottom:1px solid rgba(43,58,45,0.12); flex-wrap:wrap;">
          <span style="font-family:'Lora',serif; font-size:22px; color:#B58A47; min-width:108px; font-weight:500;">10:00 AM</span>
          <span style="font-size:19px; color:#2B3A2D; font-weight:500;">Vinyasa</span>
        </div>
        <div style="display:flex; align-items:baseline; gap:clamp(16px,4vw,48px); padding:24px 4px; border-bottom:1px solid rgba(43,58,45,0.12); flex-wrap:wrap;">
          <span style="font-family:'Lora',serif; font-size:22px; color:#B58A47; min-width:108px; font-weight:500;">12:00 PM</span>
          <span style="font-size:19px; color:#2B3A2D; font-weight:500;">Power Vinyasa</span>
        </div>
        <div style="display:flex; align-items:baseline; gap:clamp(16px,4vw,48px); padding:24px 4px; border-bottom:1px solid rgba(43,58,45,0.12); flex-wrap:wrap; background:rgba(183,138,71,0.07);">
          <span style="font-family:'Lora',serif; font-size:22px; color:#B58A47; min-width:108px; font-weight:500;">1:30 PM</span>
          <span style="display:flex; flex-direction:column; gap:4px;">
            <span style="font-size:19px; color:#2B3A2D; font-weight:500;">Speaker, donation presentation & raffle</span>
            <span style="font-size:14.5px; color:#6B6B5F;">A short community moment for everyone — not a yoga class.</span>
          </span>
        </div>
        <div style="display:flex; align-items:baseline; gap:clamp(16px,4vw,48px); padding:24px 4px; border-bottom:1px solid rgba(43,58,45,0.12); flex-wrap:wrap;">
          <span style="font-family:'Lora',serif; font-size:22px; color:#B58A47; min-width:108px; font-weight:500;">3:00 PM</span>
          <span style="font-size:19px; color:#2B3A2D; font-weight:500;">Gentle / Beginner Vinyasa</span>
        </div>
        <div style="display:flex; align-items:baseline; gap:clamp(16px,4vw,48px); padding:24px 4px; border-bottom:1px solid rgba(43,58,45,0.12); flex-wrap:wrap;">
          <span style="font-family:'Lora',serif; font-size:22px; color:#B58A47; min-width:108px; font-weight:500;">5:00 PM</span>
          <span style="font-size:19px; color:#2B3A2D; font-weight:500;">Vinyasa</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INCLUDED + EXPERIENCE ============ -->
  <section id="included" style="padding:clamp(64px,8vw,104px) 24px; background:#EDE5D4;">
    <div style="max-width:1180px; margin:0 auto;">
      <div data-reveal style="margin-bottom:clamp(48px,6vw,72px);">
        <div style="margin-bottom:clamp(28px,4vw,42px);">
          <p class="eyebrow">What's included</p>
          <h2 class="section-heading" style="font-size:clamp(28px,3.6vw,42px); line-height:1.1;">Your registration includes</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:clamp(32px,5vw,64px); align-items:stretch;">
          <div style="border-radius:16px; overflow:hidden; min-height:clamp(260px,30vw,340px); position:relative;">
            <img src="/assets/lions.jpg" alt="Two rescued lions resting in the prairie grass at The Wild Animal Sanctuary" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 40%;" loading="lazy" />
          </div>
          <div style="display:flex; flex-direction:column; gap:2px; justify-content:center;">
            <div style="display:flex; gap:14px; padding:14px 0; border-bottom:1px solid rgba(43,58,45,0.14);"><span style="color:#B58A47; font-size:18px; line-height:1.5;">&#10022;</span><span style="font-size:17px; line-height:1.5; color:#3C3C34;">One 60-minute yoga class</span></div>
            <div style="display:flex; gap:14px; padding:14px 0; border-bottom:1px solid rgba(43,58,45,0.14);"><span style="color:#B58A47; font-size:18px; line-height:1.5;">&#10022;</span><span style="font-size:17px; line-height:1.5; color:#3C3C34;">Full-day admission to The Wild Animal Sanctuary</span></div>
            <div style="display:flex; gap:14px; padding:14px 0; border-bottom:1px solid rgba(43,58,45,0.14);"><span style="color:#B58A47; font-size:18px; line-height:1.5;">&#10022;</span><span style="font-size:17px; line-height:1.5; color:#3C3C34;">Access to the 1.5-mile elevated walkway</span></div>
            <div style="display:flex; gap:14px; padding:14px 0;"><span style="color:#B58A47; font-size:18px; line-height:1.5;">&#10022;</span><span style="font-size:17px; line-height:1.5; color:#3C3C34;">A chance to support rescued animals through direct community action</span></div>
          </div>
        </div>
      </div>

      <div data-reveal>
        <p class="eyebrow" style="margin-bottom:28px;">What to expect</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:18px;">
          <div style="background:#FBF8F1; border-radius:14px; padding:26px;">
            <span style="font-family:'Lora',serif; font-size:30px; color:#B58A47;">1</span>
            <h3 style="margin:10px 0 8px; font-family:'Lora',serif; font-size:19px; color:#2B3A2D; font-weight:600;">Arrive & check in</h3>
            <p style="margin:0; font-size:15px; line-height:1.6; color:#5A5A50;">Check in at the main ticket booth at the Welcome Center with your registration confirmation.</p>
          </div>
          <div style="background:#FBF8F1; border-radius:14px; padding:26px;">
            <span style="font-family:'Lora',serif; font-size:30px; color:#B58A47;">2</span>
            <h3 style="margin:10px 0 8px; font-family:'Lora',serif; font-size:19px; color:#2B3A2D; font-weight:600;">Explore the Sanctuary</h3>
            <p style="margin:0; font-size:15px; line-height:1.6; color:#5A5A50;">Spend as much time as you like along the elevated walkway, Education Center, and public spaces.</p>
          </div>
          <div style="background:#FBF8F1; border-radius:14px; padding:26px;">
            <span style="font-family:'Lora',serif; font-size:30px; color:#B58A47;">3</span>
            <h3 style="margin:10px 0 8px; font-family:'Lora',serif; font-size:19px; color:#2B3A2D; font-weight:600;">Take your class</h3>
            <p style="margin:0; font-size:15px; line-height:1.6; color:#5A5A50;">Classes are held indoors on the Mezzanine in the Welcome Center, overlooking the walkway.</p>
          </div>
          <div style="background:#FBF8F1; border-radius:14px; padding:26px;">
            <span style="font-family:'Lora',serif; font-size:30px; color:#B58A47;">4</span>
            <h3 style="margin:10px 0 8px; font-family:'Lora',serif; font-size:19px; color:#2B3A2D; font-weight:600;">Join the community moment</h3>
            <p style="margin:0; font-size:15px; line-height:1.6; color:#5A5A50;">A short speaker presentation, donation presentation, and raffle drawing at 1:30 PM.</p>
          </div>
          <div style="background:#FBF8F1; border-radius:14px; padding:26px;">
            <span style="font-family:'Lora',serif; font-size:30px; color:#B58A47;">5</span>
            <h3 style="margin:10px 0 8px; font-family:'Lora',serif; font-size:19px; color:#2B3A2D; font-weight:600;">Support further</h3>
            <p style="margin:0; font-size:15px; line-height:1.6; color:#5A5A50;">Become a member, make a donation, or visit the gift shop to support the Sanctuary onsite.</p>
          </div>
        </div>
        <div class="gridline-container" style="margin-top:40px; grid-template-columns:repeat(auto-fit, minmax(260px,1fr));">
          <div class="gridline-cell" style="display:flex; align-items:center; justify-content:center; gap:20px;">
            <span style="font-family:'Lora',serif; font-size:40px; color:#B58A47; line-height:1; min-width:46px; text-align:center;">60</span>
            <div>
              <p style="margin:0; font-size:16px; font-weight:600; color:#2B3A2D;">Minutes per class</p>
              <p style="margin:5px 0 0; font-size:14.5px; line-height:1.5; color:#6B6B5F;">Each yoga session runs a full hour.</p>
            </div>
          </div>
          <div class="gridline-cell" style="display:flex; align-items:center; justify-content:center; gap:20px;">
            <span style="font-family:'Lora',serif; font-size:34px; color:#B58A47; line-height:1; min-width:46px; text-align:center;">&#10022;</span>
            <div>
              <p style="margin:0; font-size:16px; font-weight:600; color:#2B3A2D;">Bring your own mat</p>
              <p style="margin:5px 0 0; font-size:14.5px; line-height:1.5; color:#6B6B5F;">Mats are not provided onsite.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SANCTUARY ============ -->
  <section id="sanctuary" style="padding:clamp(64px,8vw,104px) 24px;">
    <div style="max-width:1180px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:clamp(32px,5vw,72px); align-items:start;">
      <div data-reveal>
        <p class="eyebrow">The venue</p>
        <h2 class="section-heading" style="font-size:clamp(30px,4vw,46px);">About The Wild Animal Sanctuary</h2>
        <p style="margin:22px 0 0; font-size:18px; line-height:1.75; color:#4A4A42;">Located in Keenesburg, Colorado, the Sanctuary provides large-acreage habitats and lifelong care for rescued captive wild animals. Visitors experience it from an elevated walkway designed to allow viewing without disturbing the animals.</p>
        <a href="https://www.wildanimalsanctuary.org" target="_blank" rel="noopener" class="link-gold" style="margin-top:26px;">Visit WildAnimalSanctuary.org &rarr;</a>
      </div>
      <div data-reveal class="gridline-container" style="grid-template-columns:1fr; border-radius:14px;">
        <div class="gridline-cell" style="padding:18px 22px;"><span style="font-size:16px; color:#3C3C34;">1.5-mile elevated walkway</span></div>
        <div class="gridline-cell" style="padding:18px 22px;"><span style="font-size:16px; color:#3C3C34;">Welcome Center with food, shops, restrooms & rest areas</span></div>
        <div class="gridline-cell" style="padding:18px 22px;"><span style="font-size:16px; color:#3C3C34;">Education Center on rescue & the captive wildlife crisis</span></div>
